---
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---
<footer class="mt-24 border-t border-line py-10">
  <div class="shell flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
    <div>
      <p class="eyebrow">Independent research & engineering</p>
      <p class="mt-3 max-w-md text-sm leading-6 text-muted">Exploring software that preserves context, respects agency, and remains useful without the cloud.</p>
    </div>
    <div class="flex gap-5 font-mono text-[11px] uppercase tracking-wider text-muted">
      <a href={`${base}about/`} class="no-underline hover:text-signal">About</a>
      <span>© {new Date().getFullYear()}</span>
    </div>
  </div>
</footer>
