---
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const current = Astro.url.pathname;
const links = [
  ['Research', 'research/'], ['Projects', 'projects/'], ['Notes', 'notes/'], ['About', 'about/']
];
---
<header class="border-b border-line">
  <div class="shell flex h-20 items-center justify-between">
    <a href={base} class="group flex items-center gap-3 no-underline" aria-label="Home">
      <span class="grid size-8 place-items-center border border-line font-mono text-xs text-signal transition-colors group-hover:border-signal">V</span>
      <span class="hidden text-sm font-medium tracking-wide sm:block">Vivek <span class="text-dim">/ Research & Engineering</span></span>
    </a>
    <nav aria-label="Primary navigation">
      <ul class="flex items-center gap-4 sm:gap-7">
        {links.map(([label, path]) => (
          <li><a href={`${base}${path}`} class:list={["font-mono text-[11px] uppercase tracking-wider no-underline transition-colors hover:text-ink", current.includes(`/${path}`) ? 'text-signal' : 'text-muted']}>{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>
