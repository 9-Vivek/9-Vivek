---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocumentCard from '../../components/DocumentCard.astro';
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const docs = await getCollection('projects');
---
<BaseLayout title="Projects — Vivek" description="Local-first applications, developer tools, projection engines, and distributed-systems research.">
  <header class="shell py-16 sm:py-24"><p class="eyebrow">Engineering index</p><div class="mt-6 grid gap-8 lg:grid-cols-[1fr_1fr]"><h1 class="text-5xl font-medium tracking-[-.04em] sm:text-6xl">Systems as working arguments.</h1><p class="max-w-xl self-end text-lg leading-8 text-muted">Applications, protocols, and experiments that test ideas about context, ownership, and the shape of digital work.</p></div></header>
  <section class="shell pb-16">{docs.map((doc, i) => <DocumentCard title={doc.data.title} description={doc.data.description} href={`${base}projects/${doc.id}/`} tags={doc.data.tags} index={String(i+1).padStart(2,'0')} label={doc.data.category} />)}</section>
</BaseLayout>
