---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocumentCard from '../../components/DocumentCard.astro';
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const docs = await getCollection('commercial');
---
<BaseLayout title="Applied Work — Vivek Pragada" description="Applied products and initiatives emerging from ACC research.">
  <header class="shell py-14 sm:py-20"><p class="eyebrow">Applied Work</p><div class="mt-5 max-w-2xl"><h1 class="text-4xl font-medium tracking-[-.035em] sm:text-5xl">Real User-facing Projects</h1><p class="mt-6 text-base leading-8 text-muted">Products and initiatives with a clearer external use case, while retaining the principles of legibility, user control, and technical depth.</p></div></header>
  <section class="shell pb-16">{docs.map((doc, i) => <DocumentCard title={doc.data.title} description={doc.data.description} href={`${base}commercial/${doc.id}/`} tags={doc.data.tags} index={String(i+1).padStart(2,'0')} label={doc.data.category} />)}</section>
</BaseLayout>
