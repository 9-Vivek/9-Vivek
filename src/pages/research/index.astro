---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocumentCard from '../../components/DocumentCard.astro';
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const docs = (await getCollection('research')).sort((a,b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---
<BaseLayout title="Research — Vivek" description="Research into Active Cognition Computing and cognitive-centric software.">
  <header class="shell py-16 sm:py-24"><p class="eyebrow">Research index</p><div class="mt-6 grid gap-8 lg:grid-cols-[1fr_1fr]"><h1 class="text-5xl font-medium tracking-[-.04em] sm:text-6xl">Models for software that can hold context.</h1><p class="max-w-xl self-end text-lg leading-8 text-muted">Working papers and frameworks at the intersection of HCI, cognitive tools, and local-first architecture.</p></div></header>
  <section class="shell pb-16">{docs.map((doc, i) => <DocumentCard title={doc.data.title} description={doc.data.description} href={`${base}research/${doc.id}/`} tags={doc.data.tags} index={String(i+1).padStart(2,'0')} label={doc.data.category} />)}</section>
</BaseLayout>
