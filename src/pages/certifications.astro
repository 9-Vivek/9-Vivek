---
import BaseLayout from '../layouts/BaseLayout.astro';
const certifications = [
  ['PCPP1', 'Certified Professional in Python Programming 1', 'Advanced object-oriented programming, Python enhancement proposals, GUI development, and engineering conventions beyond application-level scripting.'],
  ['PCPP2', 'Certified Professional in Python Programming 2', 'Professional Python architecture, design patterns, networking, persistence, testing, and the practices used to build maintainable systems.'],
  ['AWS Developer', 'AWS Certified Developer — Associate', 'Building, deploying, debugging, and operating applications on AWS with attention to service integration and cloud-native development workflows.'],
  ['AWS Machine Learning', 'AWS Certified Machine Learning', 'Designing and implementing machine-learning workloads across data preparation, modeling, deployment, monitoring, and responsible operation.'],
  ['NVIDIA Deep Learning', 'NVIDIA Deep Learning Institute', 'Practical training in neural-network development, accelerated computing, and the implementation of modern deep-learning workflows.'],
];
---
<BaseLayout title="Certifications — Vivek Pragada" description="Professional certifications in Python, AWS development, machine learning, and deep learning.">
  <article class="shell py-14 sm:py-20">
    <header class="max-w-2xl pb-12"><p class="eyebrow">Certifications</p><h1 class="mt-5 text-4xl font-medium tracking-[-.035em] sm:text-5xl">Professional Credentials</h1><p class="mt-6 text-base leading-8 text-muted">Certifications are included here as evidence of technical breadth. They complement project work; they are not a substitute for it.</p></header>
    <section class="border-t border-line">
      {certifications.map(([short, title, description], i) => (
        <article class="grid gap-4 border-b border-line py-7 sm:grid-cols-[42px_165px_1fr]">
          <span class="font-mono text-[10px] text-dim">{String(i + 1).padStart(2, '0')}</span>
          <div><p class="font-mono text-[10px] uppercase tracking-wider text-signal">{short}</p><h2 class="mt-2 text-sm font-medium leading-6">{title}</h2></div>
          <p class="text-sm leading-7 text-muted">{description}</p>
        </article>
      ))}
    </section>
  </article>
</BaseLayout>
