---
import '../styles/global.css';
import SideNav from '../components/SideNav.astro';
import Footer from '../components/Footer.astro';

interface Props { title?: string; description?: string; }
const {
  title = 'Vivek Pragada — Research & Engineering',
  description = 'Research and engineering at the intersection of active cognition, local-first software, and sovereign data systems.'
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const socialImage = new URL(`${base}og.png`, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0d0f0f" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="fixed left-4 top-4 z-50 -translate-y-24 bg-signal px-4 py-2 text-sm text-canvas no-underline focus:translate-y-0">Skip to content</a>
    <div class="site-frame">
      <SideNav />
      <div class="content-column">
        <main id="main"><slot /></main>
        <Footer />
      </div>
    </div>
  </body>
</html>
